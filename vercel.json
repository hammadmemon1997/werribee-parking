{
  "buildCommand": "",
  "outputDirectory": ".",
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "Service-Worker-Allowed": "/", "Cache-Control": "no-cache" } },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/icon-192.png", "dest": "/icon-192.png" },
    { "src": "/icon-512.png", "dest": "/icon-512.png" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/stations", "dest": "/stations/index.html" },
    { "src": "/werribee", "dest": "/werribee/index.html" },
    { "src": "/hoppers", "dest": "/hoppers/index.html" },
    { "src": "/williams", "dest": "/williams/index.html" },
    { "src": "/aircraft", "dest": "/aircraft/index.html" },
    { "src": "/laverton", "dest": "/laverton/index.html" },
    { "src": "/westona", "dest": "/westona/index.html" },
    { "src": "/altona", "dest": "/altona/index.html" },
    { "src": "/seaholme", "dest": "/seaholme/index.html" },
    { "src": "/newport", "dest": "/newport/index.html" },
    { "src": "/spotswood", "dest": "/spotswood/index.html" },
    { "src": "/yarraville", "dest": "/yarraville/index.html" },
    { "src": "/seddon", "dest": "/seddon/index.html" },
    { "src": "/footscray", "dest": "/footscray/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
